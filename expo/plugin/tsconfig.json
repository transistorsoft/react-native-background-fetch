{
  "compilerOptions": {
    "declaration": true,
    "declarationDir": "./build",
    "module": "commonjs",
    "outDir": "./build",
    "target": "esnext",
    "moduleResolution": "node",
    "strict": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"]
}
